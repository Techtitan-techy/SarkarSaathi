{
  "name": "sarkari-saathi",
  "version": "1.0.0",
  "description": "Voice-first AI assistant for Indian government scheme navigation",
  "main": "index.js",
  "scripts": {
    "start": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "install-frontend": "cd frontend && npm install",
    "deploy-lambda": "cd lambda && pip install -r requirements.txt -t .",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap"
  },
  "keywords": [
    "aws",
    "bedrock",
    "voice-assistant",
    "government-schemes",
    "india",
    "react",
    "python"
  ],
  "author": "SarkariSaathi Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "aws-cdk": "^2.118.0",
    "fast-check": "^4.5.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.478.0",
    "@aws-sdk/client-comprehend": "^3.1001.0",
    "@aws-sdk/client-dynamodb": "^3.478.0",
    "@aws-sdk/client-kms": "^3.478.0",
    "@aws-sdk/client-polly": "^3.478.0",
    "@aws-sdk/client-s3": "^3.478.0",
    "@aws-sdk/client-ssm": "^3.478.0",
    "@aws-sdk/client-transcribe": "^3.478.0",
    "@aws-sdk/client-translate": "^3.1001.0",
    "@aws-sdk/lib-dynamodb": "^3.478.0",
    "aws-cdk-lib": "^2.118.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "lib/**/*.ts",
      "lambda/**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
