# AWS Configuration
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=ap-south-1
AWS_REGION=ap-south-1

# DynamoDB Tables (populated after deployment)
USERS_TABLE=SarkariSaathi-Users
APPLICATIONS_TABLE=SarkariSaathi-Applications
SCHEMES_TABLE=SarkariSaathi-Schemes
SESSIONS_TABLE=SarkariSaathi-Sessions

# S3 Buckets (populated after deployment)
AUDIO_BUCKET=sarkari-saathi-audio-123456789012
SCHEME_DOCS_BUCKET=sarkari-saathi-schemes-123456789012
TTS_CACHE_BUCKET=sarkari-saathi-tts-cache-123456789012

# KMS (populated after deployment)
KMS_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Bhashini API Configuration (stored in SSM Parameter Store)
BHASHINI_API_KEY_PARAM=/sarkari-saathi/bhashini/api-key
BHASHINI_API_URL_PARAM=/sarkari-saathi/bhashini/api-url

# Feature Flags
ENABLE_BHASHINI=false
ENABLE_OFFLINE_MODE=false
ENABLE_DEBUG_LOGGING=true

# Performance Settings
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT_MS=30000
CACHE_EXPIRATION_SECONDS=3600

# API Gateway (populated after deployment)
API_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/dev/
